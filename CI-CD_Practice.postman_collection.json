      "name": "GET Users",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Users list is not empty\", function () {",
              "    let jsonData = pm.response.json();",
              "    pm.expect(jsonData.length).to.be.above(0);",
              "});"
